# ===========================
# AI SERVICE CONFIGURATION
# AutoGen v0.7 + Gemini + ChromaDB + MongoDB + yfinance
# ===========================
APP_NAME=FinAnalysis AI Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ===========================
# INTERNAL API SECURITY
# ===========================
INTERNAL_API_KEY=internal_api_key_between_services

# ===========================
# GOOGLE GEMINI
# Get your key from: https://aistudio.google.com/apikey
# ===========================
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ===========================
# MISTRAL OCR
# Get your key from: https://console.mistral.ai/
# ===========================
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_OCR_MODEL=mistral-ocr-latest

# ===========================
# CHROMADB (Local persistent storage)
# ===========================
CHROMA_PERSIST_DIRECTORY=./data/chromadb
CHROMA_COLLECTION_NAME=finanalysis_documents

# ===========================
# MONGODB
# ===========================
MONGODB_URI=mongodb://localhost:27017/finanalysis
MONGODB_DB_NAME=finanalysis

# ===========================
# MARKET DATA
# ===========================
NEWS_API_KEY=your_newsapi_key_here
DEFAULT_EXCHANGE_SUFFIX=.NS

# ===========================
# CORS (Node.js backend + Frontend)
# ===========================
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ===========================
# CACHE TTL (seconds)
# ===========================
STOCK_CACHE_TTL=300
NEWS_CACHE_TTL=600
ANALYSIS_CACHE_TTL=3600

# ===========================
# AUTOGEN SETTINGS
# ===========================
MAX_AGENT_TURNS=10
AGENT_TIMEOUT_SECONDS=120
