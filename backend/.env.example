# ===========================
# SERVER CONFIGURATION
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# MONGODB
# ===========================
MONGODB_URI=mongodb://localhost:27017/finanalysis
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finanalysis

# ===========================
# JWT SECRET
# ===========================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ===========================
# AI SERVICE (FastAPI)
# ===========================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=internal_api_key_between_services

# ===========================
# EXTERNAL APIs
# ===========================
NEWS_API_KEY=your_newsapi_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ===========================
# FRONTEND URL (for CORS)
# ===========================
FRONTEND_URL=http://localhost:3000

# ===========================
# RATE LIMITING
# ===========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
